# LLM API (OpenAI 兼容格式，支持 DeepSeek / 通义千问 / Kimi / 智谱等)
API_BASE_URL=https://api.deepseek.com/v1
API_KEY=sk-your-key-here
MODEL_NAME=deepseek-chat

# QQ 邮箱 SMTP
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_SENDER=your-qq@qq.com
SMTP_AUTH_CODE=your-auth-code-here
SMTP_RECEIVER=your-qq@qq.com

# 摘要设置
SUMMARY_DAYS=7
SUMMARY_LANGUAGE=zh-CN

# 知识积累
EMBEDDING_MODEL=
